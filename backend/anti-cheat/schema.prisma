datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "sync"
  recursive_type_depth = 3
}

// One document per game per player.  The m[] embedded array in the original
// MongoDB schema becomes the normalized `moves` table below.
model GameInsight {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  playedAt    DateTime @map("played_at")
  timeControl Int      @map("time_control") // 2 = blitz, 6 = rapid
  result      Int                           // 1 = win, 2 = draw, 3 = loss
  oppRating   Int      @default(0) @map("opp_rating")
  ratingDiff  Int      @default(0) @map("rating_diff")
  oppStrength Int      @default(5) @map("opp_strength")
  provisional Boolean  @default(false)
  aborted     Boolean  @default(false)
  moves       Move[]

  @@index([userId])
  @@index([playedAt])
  @@index([timeControl])
  @@index([userId, timeControl, playedAt])
  @@map("game_insights")
}

// One row per half-move.  Fields mirror the Kaladin m[] sub-document keys.
model Move {
  id        Int         @id @default(autoincrement())
  insight   GameInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  insightId Int         @map("insight_id")
  moveTime  Int         @map("move_time") // centiseconds
  blur      Boolean     @default(false)
  imbalance Int         @default(0)
  phase     Int                          // 1 = opening, 2 = middlegame, 3 = endgame
  role      Int                          // 1 = pawn … 6 = king
  variance  Int?                         // movetime-variance score (0–100 000)
  cpl       Int?                         // centipawn loss (eval-mode only)
  eval      Int?                         // centipawn evaluation (eval-mode only)

  @@index([insightId])
  @@map("moves")
}

// Job queue: one row per user to be analysed.
model AnalysisQueue {
  username    String    @id
  priority    Int       @default(0)
  startedAt   DateTime? @map("started_at")
  respondedAt DateTime? @map("responded_at")
  read        Boolean   @default(false)
  error       String?
  pred        Float?
  tc          Int?
  insight1    String?   @map("insight_1")
  insight2    String?   @map("insight_2")
  insight3    String?   @map("insight_3")

  @@map("analysis_queue")
}

// User registry: engine marks + per-time-control ratings for the dense layer.
model User {
  username      String    @id
  engineMark    Boolean   @default(false) @map("engine_mark")
  markDate      DateTime? @map("mark_date")
  ratingBlitz   Float?    @map("rating_blitz")
  ratingBlitzRd Float?    @map("rating_blitz_rd")
  ratingRapid   Float?    @map("rating_rapid")
  ratingRapidRd Float?    @map("rating_rapid_rd")

  @@map("users")
}
