# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# Local Prisma+Postgres URL (example for local dev server)
# The API key here does not contain any sensitive information.
# (CONNECT EXISTING DATABASE:
#   1. Configure your DATABASE_URL in prisma.config.ts
#   2. Run `prisma db pull` to introspect your database.
#
# CREATE NEW DATABASE:
#   Local: `npx prisma dev` (runs Postgres locally in your terminal)
#   Cloud: `npx create-db` (creates a free Prisma Postgres database)
#
# Then define your models in `prisma/schema.prisma` and run
# `prisma migrate dev` to apply your schema.
# Learn more: https://pris.ly/getting-started
# PostgreSQL connection string used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://admin:mysecretpassword@localhost:5432/zugklang-frontend"

# Secret used to sign/encrypt Auth.js session tokens.
# Generate a value with one of:
# - openssl rand -base64 32
# - npx auth secret
# - pnpm secret
# - pnpm exec auth secret
AUTH_SECRET=""  # Generate with: openssl rand -base64 32
########################################
# OAUTH PROVIDERS
########################################

# GitHub OAuth app credentials (leave empty if GitHub login is disabled).
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth app credentials (leave empty if Google login is disabled).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App URL used by Auth.js callbacks and redirects.
AUTH_URL="http://localhost:3000"

########################################
# AUTH_TRUST_HOST
########################################

# Required when deploying behind a reverse proxy
# (Nginx, Docker, AWS ALB, Railway, Render, VPS, etc).
#
# This tells Auth.js to trust the X-Forwarded-Host header
# so it can generate correct callback and redirect URLs.
#
# Automatically enabled on:
# - Vercel
# - Cloudflare Pages
#
# Safe to keep "true" in most environments.
AUTH_TRUST_HOST="true"


########################################
# AUTH_REDIRECT_PROXY_URL
########################################

# Optional.
#
# Used when your OAuth callback domain differs from your app domain.
# Example use case:
# - Preview deployments
# - Shared OAuth callback domain
# - Multi-environment setups
#
# This should point to a stable domain that handles OAuth redirects.
#
# Example:
# AUTH_REDIRECT_PROXY_URL="https://auth.myapp.com/api/auth"
#
# ⚠ IMPORTANT:
# Some providers (e.g., Apple) DO NOT support redirect proxy usage.
# For those providers, your AUTH_URL must directly match the
# registered callback URL in the provider dashboard.
#
# Leave empty if not using redirect proxy.
AUTH_REDIRECT_PROXY_URL=""

# Optional WebSocket server URL override.
# Leave empty to use same-origin /ws (recommended behind nginx/reverse proxy).
NEXT_PUBLIC_WS_URL=""

########################################
# INTER-SERVICE / ADMIN
########################################

# Shared secret for the /api/admin/ban endpoint and inter-service calls.
# Must match INTERNAL_API_SECRET in ws-server and anti-cheat.
INTERNAL_API_SECRET="change-me-shared-secret"

########################################
# REDIS
########################################

REDIS_URL="redis://localhost:6379"

########################################
# OBSERVABILITY
########################################

# OpenTelemetry — distributed tracing.
# Points to the OTel Collector in the compose stack.
OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector:4318"

# AUTH_URL and NEXT_AUTH_URL are equivalent (NEXT_AUTH_URL is deprecated)
