# backend/ws-server/.env.production
# Place at /workspaces/Zugklang/backend/ws-server/.env.production

ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ADMIN_KEY=change-me-admin-key
ANTI_CHEAT_URL=http://anti-cheat:8000
INTERNAL_API_SECRET=change-me-shared-secret   # must match anti-cheat
POD_URL=http://ws-server:8080

# Sentry — optional, leave empty to disable
SENTRY_DSN=
SENTRY_RELEASE=