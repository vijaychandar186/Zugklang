{
  "name": "zugklang-ws-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch server.ts",
    "start": "bun server.ts",
    "test": "bun test",
    "test:coverage": "./scripts/check-coverage.sh 85",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && bun format",
    "lint:strict": "eslint --max-warnings=0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": ""
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write --no-error-on-unmatched-pattern"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.0"
  },
  "dependencies": {
    "bullmq": "^5.70.1",
    "chessops": "^0.15.0",
    "ioredis": "^5.10.0",
    "zod": "^4.3.6"
  }
}
