# frontend/.env.production
# Place at /workspaces/Zugklang/frontend/.env.production

# Auth — required
AUTH_SECRET=                    # generate: openssl rand -base64 32
AUTH_URL=https://yourdomain.com
AUTH_TRUST_HOST=true

# OAuth providers (leave empty to disable)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# WebSocket URL (leave empty — nginx proxies /ws internally)
NEXT_PUBLIC_WS_URL=

# Sentry — optional, leave empty to disable
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=
