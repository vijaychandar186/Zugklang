{
  "title": "Anti-Cheat Dashboard",
  "uid": "anticheat-dashboard",
  "description": "Kaladin anti-cheat monitoring: predictions, queue status, game analytics, and engine-flagged users",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["anti-cheat", "chess", "security"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "annotations": { "list": [] },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red",   "index": 0, "text": "DOWN" },
                "1": { "color": "green", "index": 1, "text": "UP"   }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Service Status",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "anti_cheat_up",
          "instant": true,
          "legendFormat": "Status",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red",   "index": 0, "text": "UNHEALTHY" },
                "1": { "color": "green", "index": 1, "text": "HEALTHY"   }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "DB Health",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "anti_cheat_db_ok",
          "instant": true,
          "legendFormat": "DB",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10   },
              { "color": "red",    "value": 50   }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Pending Queue",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "anti_cheat_pending_queue",
          "instant": true,
          "legendFormat": "Pending",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10   },
              { "color": "red",    "value": 50   }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Engine-Flagged Users",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT COUNT(*) AS value FROM users WHERE engine_mark = true",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Total Users",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT COUNT(*) AS value FROM users",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Total Games Ingested",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT COUNT(*) AS value FROM game_insights",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Queue Monitoring",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Queue Depth Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "anti_cheat_pending_queue",
          "legendFormat": "Pending Analyses",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pred" },
            "properties": [
              { "id": "displayName", "value": "Score" },
              { "id": "custom.width", "value": 80 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 0.5  },
                    { "color": "red",    "value": 0.8  }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "username" },
            "properties": [ { "id": "custom.width", "value": 150 } ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "custom.width", "value": 200 },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [ { "color": "red", "value": null } ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "options": {
        "showHeader": true,
        "sortBy": [ { "desc": true, "displayName": "responded_at" } ]
      },
      "title": "Recent Queue Activity",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT username, ROUND(pred::numeric, 3) AS pred, tc, insight_1, insight_2, insight_3, started_at, responded_at, error FROM analysis_queue ORDER BY COALESCE(responded_at, started_at, NOW()) DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Prediction Results",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pred" },
            "properties": [
              { "id": "displayName", "value": "Score" },
              { "id": "custom.width", "value": 80 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 0.5  },
                    { "color": "red",    "value": 0.8  }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "username" },
            "properties": [ { "id": "custom.width", "value": 160 } ]
          },
          {
            "matcher": { "id": "byName", "options": "tc" },
            "properties": [
              { "id": "custom.width", "value": 70 },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "2": { "index": 0, "text": "Blitz" },
                      "6": { "index": 1, "text": "Rapid" }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "responded_at" },
            "properties": [ { "id": "custom.width", "value": 170 } ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 15 },
      "id": 9,
      "options": {
        "showHeader": true,
        "sortBy": [ { "desc": true, "displayName": "Score" } ]
      },
      "title": "Top Suspects (highest prediction scores)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT username, ROUND(pred::numeric, 4) AS pred, tc, insight_1, insight_2, insight_3, responded_at FROM analysis_queue WHERE pred IS NOT NULL ORDER BY pred DESC LIMIT 30",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 15 },
      "id": 10,
      "options": {
        "bucketSize": "auto",
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Prediction Score Distribution",
      "type": "histogram",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT pred AS score FROM analysis_queue WHERE pred IS NOT NULL ORDER BY pred",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "Game Data",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 26 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Games Ingested Per Day",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT DATE_TRUNC('day', played_at) AS time, COUNT(*) AS \"Games\" FROM game_insights WHERE $__timeFilter(played_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 5, "x": 14, "y": 26 },
      "id": 12,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "table", "placement": "bottom" },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      },
      "title": "Time Control Split",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT CASE WHEN time_control = 2 THEN 'Blitz' ELSE 'Rapid' END AS \"Time Control\", COUNT(*) AS value FROM game_insights GROUP BY time_control",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 5, "x": 19, "y": 26 },
      "id": 13,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "table", "placement": "bottom" },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "title": "Game Result Distribution",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT CASE result WHEN 1 THEN 'Win' WHEN 2 THEN 'Draw' ELSE 'Loss' END AS \"Result\", COUNT(*) AS value FROM game_insights GROUP BY result ORDER BY result",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 104,
      "title": "Engine-Marked Users",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "username" },
            "properties": [ { "id": "custom.width", "value": 180 } ]
          },
          {
            "matcher": { "id": "byName", "options": "mark_date" },
            "properties": [ { "id": "custom.width", "value": 170 } ]
          },
          {
            "matcher": { "id": "byName", "options": "rating_blitz" },
            "properties": [ { "id": "custom.width", "value": 110 }, { "id": "displayName", "value": "Blitz Rating" } ]
          },
          {
            "matcher": { "id": "byName", "options": "rating_rapid" },
            "properties": [ { "id": "custom.width", "value": 110 }, { "id": "displayName", "value": "Rapid Rating" } ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "id": 14,
      "options": {
        "showHeader": true,
        "sortBy": [ { "desc": true, "displayName": "mark_date" } ]
      },
      "title": "Recently Flagged Users",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT username, mark_date, ROUND(rating_blitz::numeric, 0) AS rating_blitz, ROUND(rating_rapid::numeric, 0) AS rating_rapid FROM users WHERE engine_mark = true ORDER BY mark_date DESC NULLS LAST LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 105,
      "title": "Move Analytics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "decimals": 2,
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 44 },
      "id": 15,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Avg Move Time",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT AVG(move_time) / 100.0 AS value FROM moves",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5    },
              { "color": "red",    "value": 15   }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 44 },
      "id": 16,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Move Blur Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT AVG(blur::int) * 100 AS value FROM moves",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 44 },
      "id": 17,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Total Moves Stored",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT COUNT(*) AS value FROM moves",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 44 },
      "id": 18,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Analyses Processed Today",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
          "rawSql": "SELECT COUNT(*) AS value FROM analysis_queue WHERE responded_at >= CURRENT_DATE",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "anticheat-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
