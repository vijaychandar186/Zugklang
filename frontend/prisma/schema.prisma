// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  flagCode      String          @default("INT")
  accounts      Account[]
  sessions      Session[]
  // Optional for WebAuthn support
  Authenticator Authenticator[]

  // Chess-specific relations
  whiteGames       Game[]            @relation("WhiteGames")
  blackGames       Game[]            @relation("BlackGames")
  ratings          Rating[]
  puzzleRating     PuzzleRating?
  analyses         GameAnalysis[]
  puzzleAttempts   PuzzleAttempt[]
  puzzleRushScores PuzzleRushScore[]
  memorySessions   MemorySession[]
  visionSessions   VisionSession[]
  passportFlags    PassportFlag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PassportFlag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flagCode  String
  createdAt DateTime @default(now())

  @@unique([userId, flagCode])
  @@index([userId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Game {
  id                 String        @id @default(cuid())
  roomId             String?       @unique
  whiteUserId        String?
  blackUserId        String?
  white              User?         @relation("WhiteGames", fields: [whiteUserId], references: [id])
  black              User?         @relation("BlackGames", fields: [blackUserId], references: [id])
  variant            String
  gameType           String
  result             String
  resultReason       String
  moves              String[]
  startingFen        String
  timeControl        Json
  whitePregameRating Int?
  blackPregameRating Int?
  whiteRatingDelta   Int?
  blackRatingDelta   Int?
  moveCount          Int
  rated              Boolean       @default(true)
  playedAt           DateTime?
  createdAt          DateTime      @default(now())
  analysis           GameAnalysis?
}

model GameAnalysis {
  id        String   @id @default(cuid())
  gameId    String   @unique
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  results   Json
  createdAt DateTime @default(now())
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // e.g. "standard" | "atomic" | "four-player" | "dice-chess" | "card-chess" | …
  variant   String   @default("standard")
  // "bullet" | "blitz" | "rapid" | "classical"
  category  String
  rating    Int      @default(700)
  rd        Float    @default(350.0)
  sigma     Float    @default(0.06)
  gameCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, variant, category])
}

model PuzzleRating {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      @default(1000)
  rd        Float    @default(350.0)
  sigma     Float    @default(0.06)
  gameCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PuzzleAttempt {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzleId   String
  difficulty String
  rating     Int
  solved     Boolean
  usedHint   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model PuzzleRushScore {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode             String
  difficulty       String
  score            Int
  mistakes         Int
  timeLimitSeconds Int?
  maxMistakes      Int?
  createdAt        DateTime @default(now())
}

model MemorySession {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode                String
  pieceCount          Int
  memorizeTimeSeconds Int
  correctPieces       Int
  totalPieces         Int
  accuracy            Float
  progressiveLevel    Int?
  createdAt           DateTime @default(now())
}

model VisionSession {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingMode      String
  colorMode         String
  timeLimitSeconds  Int
  score             Int
  totalAttempts     Int
  accuracy          Float
  avgResponseTimeMs Int
  createdAt         DateTime @default(now())
}
