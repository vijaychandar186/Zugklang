DATABASE_URL=postgresql://admin:mysecretpassword@localhost:5432/zugklang-anti-cheat
REDIS_URL=redis://localhost:6379
INTERNAL_API_SECRET=change-me-shared-secret

# Prediction score (0–1) above which a user is auto-banned from multiplayer (default: 0.9)
BAN_THRESHOLD=0.9

LOGGING_LEVEL=INFO

# --- Observability ---
# OpenTelemetry Collector endpoint (OTLP HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
