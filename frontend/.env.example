# App URL used by Auth.js callbacks and redirects.
AUTH_URL="http://localhost:3000"

# Secret used to sign/encrypt Auth.js session tokens.
# Generate a value with one of:
# - openssl rand -base64 32
# - npx auth secret
# - pnpm secret
AUTH_SECRET=""

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# GitHub OAuth app credentials (leave empty if GitHub login is disabled).
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth app credentials (leave empty if Google login is disabled).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
