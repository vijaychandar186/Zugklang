# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# Local Prisma+Postgres URL (example for local dev server)
# The API key here does not contain any sensitive information.
# (CONNECT EXISTING DATABASE:
#   1. Configure your DATABASE_URL in prisma.config.ts
#   2. Run `prisma db pull` to introspect your database.
#
# CREATE NEW DATABASE:
#   Local: `npx prisma dev` (runs Postgres locally in your terminal)
#   Cloud: `npx create-db` (creates a free Prisma Postgres database)
#
# Then define your models in `prisma/schema.prisma` and run
# `prisma migrate dev` to apply your schema.
# Learn more: https://pris.ly/getting-started
DATABASE_URL="prisma+postgres://localhost:51213/?api__c3NsbW9kZT1kaXNhYmxlJmNvbm5lY3Rpb25fbGltaXQ9MSZjb25uZWN0X3RpbWVvdXQ9MCZtYXhfaWRsZV9jb25uZWN0aW9uX2xpZmV0aW1lPTAmcG9vbF90aW1lb3V0PTAmc2luZ2xlX3VzZV9jb25uZWN0aW9ucz10cnVlJnNvY2tldF90aW1lb3V0PTAifQ"

# PostgreSQL connection string used by Prisma for custom postgres server
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Secret used to sign/encrypt Auth.js session tokens.
# Generate a value with one of:
# - openssl rand -base64 32
# - npx auth secret
# - pnpm secret
AUTH_SECRET=""  # Added by `npx auth`. Read more: https://cli.authjs.dev

# GitHub OAuth app credentials (leave empty if GitHub login is disabled).
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth app credentials (leave empty if Google login is disabled).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App URL used by Auth.js callbacks and redirects.
AUTH_URL="http://localhost:3000"