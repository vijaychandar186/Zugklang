# backend/anti-cheat/.env.production
# Place at /workspaces/Zugklang/backend/anti-cheat/.env.production

INTERNAL_API_SECRET=change-me-shared-secret   # must match ws-server and frontend
LOGGING_LEVEL=WARNING

# Prediction score (0–1) above which a user is automatically banned from multiplayer.
# Raise to 0.95 to reduce false positives, lower to 0.8 to be more aggressive.
BAN_THRESHOLD=0.9

