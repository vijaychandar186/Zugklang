datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

model User {
  id    String  @id
  marks String?

  @@map("users")
}

model Insight {
  id       String @id
  u        String?
  user_id  String?
  user     String?
  username String?
  doc      Json?

  @@map("insights")
}
