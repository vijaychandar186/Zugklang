.git
.gitignore

# Dev tooling (not needed at runtime)
.husky
.eslintrc*
eslint.config.*
prettier.config.*
.prettierrc*
.prettierignore
tsconfig*.json
*.tsbuildinfo

# Editor / OS
.vscode
.idea
.DS_Store
